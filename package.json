{
  "name": "smooth-ssh-mcp",
  "version": "0.1.0",
  "description": "An MCP server for managed OpenSSH connections, command execution, interactive sessions, file transfer, and port forwards.",
  "type": "module",
  "bin": {
    "smooth-ssh-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
